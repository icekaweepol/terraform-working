    #         tomap({"key" = "k8s.io/cluster-autoscaler/enabled", "value" = "true", "propagate_at_launch" = true}),
    #         tomap({"key" = "k8s.io/cluster-autoscaler/SCB-SIT-B-EKS", "value" = "owned", "propagate_at_launch" = true}),
    #         tomap({"key" = "aws-node-termination-handler/managed", "value" = "true", "propagate_at_launch" = true})
    #       ]),
    #       var.common_worker_tags
    #     )
    #   }"
    #   # root_volume_size      = 100
    #   root_volume_type      = "gp3"
		#   root_encrypted        = true
		#   root_kms_key_id       = var.ebs_kms_key_id      
    #   asg_recreate_on_change   = true
    #   override_instance_types  = ["m5.2xlarge", "m5a.2xlarge", "m5ad.2xlarge", "m5d.2xlarge"]
    #   subnets               = [aws_subnet.private_c.id]
    #   autoscaling_enabled   = true
    #   protect_from_scale_in = false
    #   asg_max_size          = 10
    #   asg_desired_capacity  = 0
    #   asg_min_size          = 0
    #   kubelet_extra_args    = "${var.kubelet_additional_args} --node-labels=node.kubernetes.io/lifecycle=spot,role=apps,availability_zone=c --register-with-taints=os=windows:NoSchedule"
    #   # Spot settings
    #   spot_allocation_strategy = "lowest-price"
    #   spot_instance_pools      = 10
    #   platform              = "windows"
    #   pre_userdata = <<-EOT
    #     Invoke-Expression -Command '[Environment]::SetEnvironmentVariable("EKS_CONTAINER_RUNTIME", "containerd", [System.EnvironmentVariableTarget]::Machine)'
    #   EOT      
    #   # additional_userdata   = data.template_file.windows-nodes-userdata.rendered 
    # }
  ]

  node_groups = {
    # create launch template
    APPS-NODE = {
      create_launch_template = true
      desired_capacity       = 1
      max_capacity           = 50
      min_capacity           = 1
      iam_role_arn = module.Centralized-EKS.worker_iam_role_arn
      force_update_version = true

      disk_size       = 90
      disk_type       = "gp3"
      disk_throughput = 150
      disk_iops       = 3000

      ami_type = "AL2023_x86_64_STANDARD"
      ami_release_version = var.worker_node_ami_release_version
      instance_types = ["m6a.xlarge","m5a.xlarge","r5a.xlarge","r6a.xlarge"]
      capacity_type  = "SPOT"
      pre_userdata   = data.template_file.worker-nodes-userdata.rendered
      metadata_http_put_response_hop_limit = 2

      bootstrap_env = {
        CONTAINER_RUNTIME = "containerd"
        USE_MAX_PODS      = false
      }
      kubelet_extra_args = "${var.kubelet_additional_args} --max-pods=110"
      k8s_labels = {
        role = "apps"
      }
      additional_tags = {
        AdminName = "kaweepol.khajaroenying@scb.co.th"
        AdminName2 = "suttipot.eksakulkla@scb.co.th"
        AppName   = "Kubernetes"
        Environment = "SIT"
        Company   = "SCB"
        AppID     = "AP2142"
      }
      update_config = {
        max_unavailable_percentage = 50 # or set `max_unavailable`
      }
    }
    INFRA-NODE = {
      create_launch_template = true
      desired_capacity       = 1
      max_capacity           = 50
      min_capacity           = 1
      iam_role_arn = module.Centralized-EKS.worker_iam_role_arn
      force_update_version = true

      disk_size       = 90
      disk_type       = "gp3"
      disk_throughput = 150
      disk_iops       = 3000

      ami_type = "AL2023_x86_64_STANDARD"
      ami_release_version = var.worker_node_ami_release_version
      instance_types = ["m6a.xlarge","m5a.xlarge","r5a.xlarge","r6a.xlarge"]
      capacity_type  = "SPOT"
      pre_userdata   = data.template_file.worker-nodes-userdata.rendered
      metadata_http_put_response_hop_limit = 2
      
      bootstrap_env = {
        CONTAINER_RUNTIME = "containerd"
        USE_MAX_PODS      = false
      }
      kubelet_extra_args = "${var.kubelet_additional_args} --max-pods=110"
      k8s_labels = {
        role = "infra"
      }
      additional_tags = {
        AdminName = "kaweepol.khajaroenying@scb.co.th"
        AdminName2 = "suttipot.eksakulkla@scb.co.th"
        AppName   = "Kubernetes"
        Environment = "SIT"
        Company   = "SCB"
        AppID     = "AP2142"
      }
      update_config = {
        max_unavailable_percentage = 50 # or set `max_unavailable`
      }
    }
  }

  fargate_profiles = {
    # iam_role_additional_policies = ["arn:aws:iam::aws:policy/CloudWatchLogsFullAccess"]
    pbfex-batch-profile = {
      name = "pbfex-batch-profile"
      subnets = [aws_subnet.private_a.id,aws_subnet.private_b.id,aws_subnet.private_c.id] 
      selectors = [
        {
          namespace = "pbfex-batch-dev"
          labels = {
            role = "apps-pbfex"
            WorkerType = "fargate"
          }
        },
        {
          namespace = "pbfex-batch-sit"
          labels = {
            role = "apps-pbfex"
            WorkerType = "fargate"
          }
        }
      ]
      tags = {
        Name      = "pbfex-batch-profile"
        AppName   = "PBFEX"
      }
    }
  }
}

output "eks_workers_security_group_id" {
  value      = module.Centralized-EKS.worker_security_group_id
  depends_on = [module.Centralized-EKS]
}

output "eks_cluster_security_group_id" {
  value      = module.Centralized-EKS.cluster_security_group_id
  depends_on = [module.Centralized-EKS]
}

output "eks_worker_iam_role_arn" {
  value      = module.Centralized-EKS.worker_iam_role_arn
  depends_on = [module.Centralized-EKS]
}

output "eks_cluster_oidc_issuer_url" {
  value      = module.Centralized-EKS.cluster_oidc_issuer_url
  depends_on = [module.Centralized-EKS]
}

