################################################################################
# EKS
################################################################################

module "Centralized-EKS" {

  source                          = "terraform-aws-modules/eks/aws"
  version                         = "17.20.0"
  cluster_version                 = "1.33"
  vpc_id                          = var.vpc_id
  cluster_name                    = var.cluster_name
  subnets                         = [aws_subnet.private_a.id, aws_subnet.private_b.id, aws_subnet.private_c.id]
  # cluster_enabled_log_types       = ["api", "audit", "authenticator", "controllerManager", "scheduler"]
  cluster_endpoint_private_access = true
  cluster_endpoint_public_access  = false
  cluster_endpoint_private_access_cidrs = var.api_access_cidr
  cluster_create_endpoint_private_access_sg_rule = true
  # kubeconfig_output_path	= "~/.kube/kubeconfig-b"
  # kubeconfig_aws_authenticator_command = "aws"
  # kubeconfig_aws_authenticator_command_args = [
  #     "--region",
  #     "ap-southeast-1",
  #     "eks",
  #     "get-token",
  #     "--cluster-name",
  #     "${var.cluster_name}"
  # ]


  # Enable IAM Roles for EKS Service-Accounts (IRSA).
  enable_irsa = true

  # Do not apply aws_auth by itself - needed to properlly tested this args
  manage_aws_auth = false

  # Timeout settings for cluster creation
  cluster_create_timeout = "30m"
  cluster_delete_timeout = "30m"

  # Add addtional worker nodes policy
  workers_additional_policies = ["arn:aws:iam::aws:policy/AmazonSSMManagedInstanceCore", aws_iam_policy.eks_cluster_kms_read_access.arn]
	#workers_additional_policies = ["arn:aws:iam::aws:policy/AmazonSSMManagedInstanceCore", aws_iam_policy.custom_worker_policy.arn]

  # Kubernetes Worker Nodes
  worker_groups_launch_template = [
    {
      name                          = "infra-WG-A"
      ami_id                        = var.worker_node_ami
      # ami_id                        = var.bottlerocket_ami
      instance_type                 = var.infra_instance_type
      tags = "${concat(
          tolist([
            tomap({"key" = "role", "value" = "infra", "propagate_at_launch" = true}),
            tomap({"key" = "k8s.io/cluster-autoscaler/enabled", "value" = "true", "propagate_at_launch" = true}),
            tomap({"key" = "k8s.io/cluster-autoscaler/SCB-SIT-B-EKS", "value" = "owned", "propagate_at_launch" = true})
          ]),
          var.common_worker_tags
        )
      }"
      # root_volume_size      = 100
      root_volume_type      = "gp3"
		  root_encrypted        = true
		  root_kms_key_id       = var.ebs_kms_key_id
      asg_desired_capacity          = 1
      asg_max_size                  = 10
      asg_min_size                  = 1
      kubelet_extra_args            = "${var.kubelet_additional_args} --node-labels=node.kubernetes.io/lifecycle=ondemand,role=infra,availability_zone=a"
      # bootstrap_extra_args          = "--container-runtime containerd"
      subnets                       = [aws_subnet.private_a.id]
      key_name                      = "system-admin-nonprod-b-key"
      autoscaling_enabled           = true
      protect_from_scale_in         = false
      additional_userdata           = data.template_file.worker-nodes-userdata.rendered
      
      # #Bottlerocket
      # userdata_template_file        = "${path.module}/userdata/bottlerocket-userdata.toml"
      # userdata_template_extra_args = {
      #   enable_admin_container   = false
      #   enable_control_container = true
      # }
      # additional_userdata = <<EOT
      #   [settings.kubernetes.node-labels]
      #   "node.kubernetes.io/lifecycle" = "ondemand"
      #   "role" = "infra"
      #   "availability_zone" = "a"
      # EOT
    },
    {
      name                          = "infra-WG-B"
      ami_id                        = var.worker_node_ami
      # ami_id                        = var.bottlerocket_ami      
      instance_type                 = var.infra_instance_type
      tags = "${concat(
          tolist([
            tomap({"key" = "role", "value" = "infra", "propagate_at_launch" = true}),
            tomap({"key" = "k8s.io/cluster-autoscaler/enabled", "value" = "true", "propagate_at_launch" = true}),
            tomap({"key" = "k8s.io/cluster-autoscaler/SCB-SIT-B-EKS", "value" = "owned", "propagate_at_launch" = true})
          ]),
          var.common_worker_tags
        )
      }"
      # root_volume_size      = 100
      root_volume_type      = "gp3"
		  root_encrypted        = true
		  root_kms_key_id       = var.ebs_kms_key_id      
      asg_desired_capacity          = 1
      asg_max_size                  = 10
      asg_min_size                  = 1
      kubelet_extra_args            = "${var.kubelet_additional_args} --node-labels=node.kubernetes.io/lifecycle=ondemand,role=infra,availability_zone=b"
      # bootstrap_extra_args          = "--container-runtime containerd"      
      subnets                       = [aws_subnet.private_b.id]
      autoscaling_enabled           = true
      protect_from_scale_in         = false
      additional_userdata           = data.template_file.worker-nodes-userdata.rendered

      # #Bottlerocket
      # userdata_template_file        = "${path.module}/userdata/bottlerocket-userdata.toml"
      # userdata_template_extra_args = {
      #   enable_admin_container   = false
      #   enable_control_container = true
      # }
      # additional_userdata = <<EOT
      #   [settings.kubernetes.node-labels]
      #   "node.kubernetes.io/lifecycle" = "ondemand"
      #   "role" = "infra"
      #   "availability_zone" = "b"
      # EOT      
    },
    {
      name                          = "infra-WG-C"
      ami_id                        = var.worker_node_ami
      # ami_id                        = var.bottlerocket_ami      
      instance_type                 = var.infra_instance_type

      tags = "${concat(
          tolist([
            tomap({"key" = "role", "value" = "infra", "propagate_at_launch" = true}),
            tomap({"key" = "k8s.io/cluster-autoscaler/enabled", "value" = "true", "propagate_at_launch" = true}),
            tomap({"key" = "k8s.io/cluster-autoscaler/SCB-SIT-B-EKS", "value" = "owned", "propagate_at_launch" = true})
          ]),
          var.common_worker_tags
        )
      }"
      # root_volume_size      = 100
      root_volume_type      = "gp3"
		  root_encrypted        = true
		  root_kms_key_id       = var.ebs_kms_key_id
      asg_desired_capacity          = 1
      asg_max_size                  = 10
      asg_min_size                  = 1
      kubelet_extra_args            = "${var.kubelet_additional_args} --node-labels=node.kubernetes.io/lifecycle=ondemand,role=infra,availability_zone=c"
      # bootstrap_extra_args          = "--container-runtime containerd"
      subnets                       = [aws_subnet.private_c.id]
      autoscaling_enabled           = true
      protect_from_scale_in         = false
      additional_userdata           = data.template_file.worker-nodes-userdata.rendered

      # #Bottlerocket
      # userdata_template_file        = "${path.module}/userdata/bottlerocket-userdata.toml"
      # userdata_template_extra_args = {
      #   enable_admin_container   = false
      #   enable_control_container = true
      # }
      # additional_userdata = <<EOT
      #   [settings.kubernetes.node-labels]
      #   "node.kubernetes.io/lifecycle" = "ondemand"
      #   "role" = "infra"
      #   "availability_zone" = "c"
      # EOT      
    },
    {
      name                     = "APPS-Spot-WG-A"
      ami_id                   = var.worker_node_ami
      # ami_id                   = var.bottlerocket_ami
      instance_type            = var.spot_apps_instance_type
      # key_name                 = "system-admin-nonprod-b-key"

      tags = "${concat(
          tolist([
            tomap({"key" = "role", "value" = "apps", "propagate_at_launch" = true}),
            tomap({"key" = "k8s.io/cluster-autoscaler/enabled", "value" = "true", "propagate_at_launch" = true}),
            tomap({"key" = "k8s.io/cluster-autoscaler/SCB-SIT-B-EKS", "value" = "owned", "propagate_at_launch" = true}),
            tomap({"key" = "aws-node-termination-handler/managed", "value" = "true", "propagate_at_launch" = true})
          ]),
          var.common_worker_tags
        )
      }"
      # root_volume_size      = 100
      root_volume_type      = "gp3"
		  root_encrypted        = true
		  root_kms_key_id       = var.ebs_kms_key_id
      asg_recreate_on_change   = true
      override_instance_types  = ["m5a.xlarge", "r5ad.xlarge", "i4i.xlarge"]
      subnets               = [aws_subnet.private_a.id]
      autoscaling_enabled   = true
      protect_from_scale_in = false
      asg_max_size          = 20
      asg_desired_capacity  = 1
      asg_min_size          = 1
      kubelet_extra_args    = "${var.kubelet_additional_args} --node-labels=node.kubernetes.io/lifecycle=spot,role=apps,availability_zone=a"
      # bootstrap_extra_args  = "--container-runtime containerd"
      # Spot settings
      spot_allocation_strategy = "lowest-price"
      spot_instance_pools      = 20
      additional_userdata           = data.template_file.worker-nodes-userdata.rendered

      # #Bottlerocket
      # userdata_template_file = "${path.module}/userdata/bottlerocket-userdata.toml"
      # userdata_template_extra_args = {
      #   enable_admin_container   = false
      #   enable_control_container = true
      # }
      # additional_userdata = <<EOT
      #   [settings.kubernetes.node-labels]
      #   "node.kubernetes.io/lifecycle" = "spot"
      #   "role" = "apps"
      #   "availability_zone" = "a"
      # EOT
    },
    {
      name                     = "APPS-Spot-WG-B"
      ami_id                   = var.worker_node_ami
      # ami_id                   = var.bottlerocket_ami
      instance_type            = var.spot_apps_instance_type
      # key_name                 = "system-admin-nonprod-b-key"

      tags = "${concat(
          tolist([
            tomap({"key" = "role", "value" = "apps", "propagate_at_launch" = true}),
            tomap({"key" = "k8s.io/cluster-autoscaler/enabled", "value" = "true", "propagate_at_launch" = true}),
            tomap({"key" = "k8s.io/cluster-autoscaler/SCB-SIT-B-EKS", "value" = "owned", "propagate_at_launch" = true}),
            tomap({"key" = "aws-node-termination-handler/managed", "value" = "true", "propagate_at_launch" = true})
          ]),
          var.common_worker_tags
        )
      }"
      # root_volume_size      = 100
      root_volume_type      = "gp3"
		  root_encrypted        = true
		  root_kms_key_id       = var.ebs_kms_key_id
      asg_recreate_on_change   = true
      override_instance_types  = ["m5a.xlarge", "r5ad.xlarge", "i4i.xlarge"]
      subnets               = [aws_subnet.private_b.id]
      autoscaling_enabled   = true
      protect_from_scale_in = false
      asg_max_size          = 20
      asg_desired_capacity  = 1
      asg_min_size          = 1
      kubelet_extra_args    = "${var.kubelet_additional_args} --node-labels=node.kubernetes.io/lifecycle=spot,role=apps,availability_zone=b"      
      # bootstrap_extra_args  = "--container-runtime containerd"      
      # Spot settings
      spot_allocation_strategy = "lowest-price"
      spot_instance_pools      = 20
      additional_userdata      = data.template_file.worker-nodes-userdata.rendered

      # #Bottlerocket
      # userdata_template_file = "${path.module}/userdata/bottlerocket-userdata.toml"
      # userdata_template_extra_args = {
      #   enable_admin_container   = false
      #   enable_control_container = true
      # }
      # additional_userdata = <<EOT
      #   [settings.kubernetes.node-labels]
      #   "node.kubernetes.io/lifecycle" = "spot"
      #   "role" = "apps"
      #   "availability_zone" = "b"
      # EOT
    },
    {
      name                     = "APPS-Spot-WG-C"
      ami_id                   = var.worker_node_ami
      # ami_id                   = var.bottlerocket_ami
      instance_type            = var.spot_apps_instance_type
      # key_name                 = "system-admin-nonprod-b-key"

      tags = "${concat(
          tolist([
            tomap({"key" = "role", "value" = "apps", "propagate_at_launch" = true}),
            tomap({"key" = "k8s.io/cluster-autoscaler/enabled", "value" = "true", "propagate_at_launch" = true}),
            tomap({"key" = "k8s.io/cluster-autoscaler/SCB-SIT-B-EKS", "value" = "owned", "propagate_at_launch" = true}),
            tomap({"key" = "aws-node-termination-handler/managed", "value" = "true", "propagate_at_launch" = true})
          ]),
          var.common_worker_tags
        )
      }"
      # root_volume_size      = 100
      root_volume_type      = "gp3"
		  root_encrypted        = true
		  root_kms_key_id       = var.ebs_kms_key_id
      asg_recreate_on_change   = true
      override_instance_types  = ["m5a.xlarge", "r5ad.xlarge", "i4i.xlarge"]
      subnets               = [aws_subnet.private_c.id]
      autoscaling_enabled   = true
      protect_from_scale_in = false
      asg_max_size          = 20
      asg_desired_capacity  = 1
      asg_min_size          = 1
      kubelet_extra_args    = "${var.kubelet_additional_args} --node-labels=node.kubernetes.io/lifecycle=spot,role=apps,availability_zone=c"
      # bootstrap_extra_args  = "--container-runtime containerd"
      # Spot settings
      spot_allocation_strategy = "lowest-price"
      spot_instance_pools      = 20
      additional_userdata      = data.template_file.worker-nodes-userdata.rendered
      
      # #Bottlerocket
      # userdata_template_file = "${path.module}/userdata/bottlerocket-userdata.toml"
      # userdata_template_extra_args = {
      #   enable_admin_container   = false
      #   enable_control_container = true
      # }
      # additional_userdata = <<EOT
      #   [settings.kubernetes.node-labels]
      #   "node.kubernetes.io/lifecycle" = "spot"
      #   "role" = "apps"
      #   "availability_zone" = "c"
      # EOT
    }    
    # {
    #   name                     = "APPS-Windows-Spot-WG-A"
    #   ami_id                   = var.windows_ami
    #   instance_type            = var.spot_apps_instance_type
    #   # key_name                 = "system-admin-nonprod-b-key"

