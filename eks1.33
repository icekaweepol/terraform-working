################################################################################
## Subnets
################################################################################

resource "aws_subnet" "private_a" {
  vpc_id            = var.vpc_id
  cidr_block        = var.private_subnet_a_cidr_range
  availability_zone = "ap-southeast-1a"
  tags = {
      "Name"                                      = "${var.cluster_name}_private_a"
      "kubernetes.io/cluster/${var.cluster_name}" = "shared"
      "kubernetes.io/role/elb"                    = "true"
      "kubernetes.io/role/internal-elb"           = "true"    
    }
}

resource "aws_subnet" "private_b" {
  vpc_id            = var.vpc_id
  cidr_block        = var.private_subnet_b_cidr_range
  availability_zone = "ap-southeast-1b"
  tags = {
      "Name"                                      = "${var.cluster_name}_private_b"
      "kubernetes.io/cluster/${var.cluster_name}" = "shared"
      "kubernetes.io/role/elb"                    = "true"
      "kubernetes.io/role/internal-elb"           = "true"
    }
}

resource "aws_subnet" "private_c" {
  vpc_id            = var.vpc_id
  cidr_block        = var.private_subnet_c_cidr_range
  availability_zone = "ap-southeast-1c"
  tags = {
      "Name"                                      = "${var.cluster_name}_private_c"
      "kubernetes.io/cluster/${var.cluster_name}" = "shared"
      "kubernetes.io/role/elb"                    = "true"
      "kubernetes.io/role/internal-elb"           = "true"
    }
}


########################
## Route Tables
########################


resource "aws_route_table_association" "priv_subnet_a" {
  subnet_id      = aws_subnet.private_a.id
  route_table_id = var.private_routetable_id
  depends_on     = [aws_subnet.private_a]
  # depends_on     = ["aws_subnet.private_a", "aws_route_table.env_private"]
}

resource "aws_route_table_association" "priv_subnet_b" {
  subnet_id      = aws_subnet.private_b.id
  route_table_id = var.private_routetable_id
  depends_on     = [aws_subnet.private_b]
  # depends_on     = ["aws_subnet.private_b", "aws_route_table.env_private"]
}

resource "aws_route_table_association" "priv_subnet_c" {
  subnet_id      = aws_subnet.private_c.id
  route_table_id = var.private_routetable_id
  depends_on     = [aws_subnet.private_c]
  # depends_on     = ["aws_subnet.private_c", "aws_route_table.env_private"]
}

################################################################################
## Secondary Subnets
################################################################################

resource "aws_subnet" "secondary_private_a" {
  vpc_id            = var.vpc_id
  cidr_block        = var.secondary_private_subnet_a_cidr_range
  availability_zone = "ap-southeast-1a"
  tags = {
      "Name"                                      = "${var.cluster_name}_secondary_private_a"
      "kubernetes.io/cluster/${var.cluster_name}" = "shared"
    }
}

resource "aws_subnet" "secondary_private_b" {
  vpc_id            = var.vpc_id
  cidr_block        = var.secondary_private_subnet_b_cidr_range
  availability_zone = "ap-southeast-1b"
  tags = {
      "Name"                                      = "${var.cluster_name}_secondary_private_b"
      "kubernetes.io/cluster/${var.cluster_name}" = "shared"
    }
}

resource "aws_subnet" "secondary_private_c" {
  vpc_id            = var.vpc_id
  cidr_block        = var.secondary_private_subnet_c_cidr_range
  availability_zone = "ap-southeast-1c"
  tags = {
      "Name"                                      = "${var.cluster_name}_secondary_private_c"
      "kubernetes.io/cluster/${var.cluster_name}" = "shared"
    }
}

resource "aws_route_table_association" "secondary_priv_subnet_a" {
  subnet_id      = aws_subnet.secondary_private_a.id
  route_table_id = var.secondary_private_routetable_id
  depends_on     = [aws_subnet.secondary_private_a]
  # depends_on     = ["aws_subnet.secondary_private_a", "aws_route_table.env_secondary_private"]
}

resource "aws_route_table_association" "secondary_priv_subnet_b" {
  subnet_id      = aws_subnet.secondary_private_b.id
  route_table_id = var.secondary_private_routetable_id
  depends_on     = [aws_subnet.secondary_private_b]
  # depends_on     = ["aws_subnet.secondary_private_b", "aws_route_table.env_secondary_private"]
}

resource "aws_route_table_association" "secondary_priv_subnet_c" {
  subnet_id      = aws_subnet.secondary_private_c.id
  route_table_id = var.secondary_private_routetable_id
  depends_on     = [aws_subnet.secondary_private_c]
  # depends_on     = ["aws_subnet.secondary_private_c", "aws_route_table.env_secondary_private"]
}

