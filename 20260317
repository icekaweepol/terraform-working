data "aws_security_group" "worker_nodes" {
  id = "sg-0ad52ae182f9e4ea1"	#SCB-UAT-1-EKS-node2023110909105129930000000a
}

resource "aws_launch_template" "infra_template" {
  name_prefix   = "${var.cluster_name}-infra-WG-"
  instance_type = var.infra_instance_type
  update_default_version = true
  image_id = var.worker_node_ami
  #key_name                 = "system-admin-nonprod-key"
  user_data = base64encode(
    data.template_file.worker-nodes-userdata-infra.rendered
  )

  vpc_security_group_ids = [
    data.aws_security_group.worker_nodes.id
  ]

  iam_instance_profile {
    arn = var.IAM_Instance_Profile
  }

  block_device_mappings {
    device_name = "/dev/xvda"
    ebs {
      volume_size           = 100
      volume_type           = "gp3"
      encrypted             = true
      delete_on_termination = true
      kms_key_id            = var.ebs_kms_key_id
    }
  }
}


