  iam_role_name                      = var.cluster_name
  cluster_security_group_name        = var.cluster_name
  cluster_security_group_description = "EKS cluster security group."   

  # Enable IAM Roles for EKS Service-Accounts (IRSA).
  enable_irsa = true

