   create = "30m"
   delete = "30m"
    }

  # Additional SG for HTTPS
  node_security_group_additional_rules = {
    ingress_self_all = {
      description = "Node to node communication via HTTPS port"
      protocol    = "tcp"
      from_port   = 443
      to_port     = 443
      type        = "ingress"
      self        = true
    }
    ingress_self_all_80 = {
      description = "Node to node communication via HTTP port"
      protocol    = "tcp"
      from_port   = 80
      to_port     = 80
      type        = "ingress"
      self        = true
    }        
  }

